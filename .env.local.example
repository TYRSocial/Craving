# MongoDB Connection String
# For Local Development: mongodb://localhost:27017/craving
# For MongoDB Atlas Cloud: mongodb+srv://username:password@cluster.mongodb.net/craving?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/craving?retryWrites=true&w=majority

# JWT Secret (generate a random string)
JWT_SECRET=your_jwt_secret_key_change_this_to_something_secure

# NextAuth Config
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_change_this_to_something_secure

# API Keys (Optional)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
